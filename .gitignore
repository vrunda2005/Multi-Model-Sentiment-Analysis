# ==============================================================================
# Python & Virtual Environments
# ==============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
bin/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
.venv/
venv/
ENV/
env/
pyvenv.cfg

# ==============================================================================
# Jupyter Notebooks & IDEs
# ==============================================================================
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# VS Code & PyCharm
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ==============================================================================
# Operating System Files
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==============================================================================
# Project-Specific: Data, Models, & Logs (Crucial for ML Projects)
# ==============================================================================
# Large data files/folders (allows keeping the directory structure via .gitkeep)
data/**
!data/
!data/**/.gitkeep

# Serialized models and large binary weight files (prevent pushing to GitHub)
*.pkl
*.pkl.gz
*.joblib
*.h5
*.pb
*.pt
*.pth
*.ckpt
*.onnx
*.weights
*.bin
*.model
experiments/models/**
!experiments/models/
!experiments/models/**/.gitkeep

# ML Experiment Logs
mlruns/
.mlflow/
lightning_logs/
wandb/
.tensorboard/
*.log

# ==============================================================================
# Secrets & Configurations
# ==============================================================================
# Local environment variables / credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Streamlit secrets (if used in dashboard)
.streamlit/secrets.toml